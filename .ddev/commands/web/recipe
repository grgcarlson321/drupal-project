#!/usr/bin/env bash

## Description: Apply a local recipe by merging dependencies and running recipe
## Usage: recipe [recipe-name]
## Example: ddev recipe formula-foundational

set -e

# Exclude list - recipes to skip in interactive mode
EXCLUDE_LIST=("formula-foundational")

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

# Function to check if recipe is in exclude list
is_excluded() {
    local recipe=$1
    for excluded in "${EXCLUDE_LIST[@]}"; do
        if [ "$recipe" = "$excluded" ]; then
            return 0
        fi
    done
    return 1
}

# Function to get recipe display name from recipe.yml
get_recipe_display_name() {
    local recipe_path=$1
    if [ -f "$recipe_path/recipe.yml" ]; then
        local name=$(grep -E "^name:" "$recipe_path/recipe.yml" | sed 's/name:\s*//' | tr -d '"' | tr -d "'")
        if [ -n "$name" ]; then
            echo "$name"
        else
            basename "$recipe_path"
        fi
    else
        basename "$recipe_path"
    fi
}

# Function to apply a single recipe
apply_recipe() {
    local RECIPE_NAME=$1
    local RECIPE_PATH="/var/www/html/recipes/$RECIPE_NAME"
    local ROOT_COMPOSER="/var/www/html/composer.json"

    print_info "Starting recipe application: $RECIPE_NAME"
    echo ""

    # Step 1: Validate recipe exists
    print_info "Step 1/5: Validating recipe..."
    if [ ! -d "$RECIPE_PATH" ]; then
        print_error "Recipe directory not found: recipes/$RECIPE_NAME"
        return 1
    fi

    if [ ! -f "$RECIPE_PATH/recipe.yml" ]; then
        print_error "recipe.yml not found in: recipes/$RECIPE_NAME"
        return 1
    fi

    print_success "Recipe validated: $RECIPE_PATH"
    echo ""

    # Step 2: Merge dependencies if composer.json exists
    if [ -f "$RECIPE_PATH/composer.json" ]; then
        print_info "Step 2/5: Merging composer dependencies..."

        # Ensure jq is installed
        if ! command -v jq &> /dev/null; then
            print_warning "jq not found, attempting to install..."
            apt-get update -qq && apt-get install -y -qq jq > /dev/null 2>&1
        fi

        # Extract dependencies from recipe's composer.json
        RECIPE_DEPS=$(jq -r '.require // {} | to_entries | map("\(.key):\(.value)") | join(" ")' "$RECIPE_PATH/composer.json")
        RECIPE_DEV_DEPS=$(jq -r '."require-dev" // {} | to_entries | map("\(.key):\(.value)") | join(" ")' "$RECIPE_PATH/composer.json")

        if [ -n "$RECIPE_DEPS" ] && [ "$RECIPE_DEPS" != "" ]; then
            print_info "Found dependencies to merge: $(echo "$RECIPE_DEPS" | wc -w | tr -d ' ') packages"
            print_warning "This may take a few minutes..."

            # Use composer require to add all dependencies
            if composer require $RECIPE_DEPS --working-dir=/var/www/html --no-interaction; then
                print_success "Dependencies merged and installed"
            else
                print_error "Failed to install dependencies"
                return 1
            fi
        else
            print_warning "No require dependencies found in recipe's composer.json"
        fi

        if [ -n "$RECIPE_DEV_DEPS" ] && [ "$RECIPE_DEV_DEPS" != "" ]; then
            print_info "Found dev dependencies to merge: $(echo "$RECIPE_DEV_DEPS" | wc -w | tr -d ' ') packages"

            # Use composer require --dev for dev dependencies
            if composer require --dev $RECIPE_DEV_DEPS --working-dir=/var/www/html --no-interaction; then
                print_success "Dev dependencies merged and installed"
            else
                print_warning "Failed to install dev dependencies (continuing anyway)"
            fi
        fi
    else
        print_warning "Step 2/5: No composer.json found in recipe, skipping dependency merge"
    fi
    echo ""

    # Step 3: Clear Drupal cache
    print_info "Step 3/6: Clearing Drupal cache..."
    cd /var/www/html/web
    if drush cache:rebuild > /dev/null 2>&1; then
        print_success "Cache cleared"
    else
        print_warning "Could not clear cache (site may not be installed yet)"
    fi
    echo ""

    # Step 4: Pre-install all modules from recipe to avoid install-order conflicts.
    # When drush recipe installs modules one-by-one, a later module's install hook
    # (e.g. scheduler) can trigger calculateDependencies() on existing entity displays
    # that reference formatter plugins from modules not yet installed (e.g. svg_image).
    # Pre-installing everything first, then doing a cache rebuild, ensures all plugin
    # managers are warm before the recipe runs its config import phase.
    if [ -f "$RECIPE_PATH/recipe.yml" ]; then
        RECIPE_MODULES=$(grep -A 200 '^install:' "$RECIPE_PATH/recipe.yml" \
            | grep -E '^\s+-\s+\S+' \
            | sed 's/^\s*-\s*//' \
            | tr '\n' ' ')

        if [ -n "$RECIPE_MODULES" ]; then
            print_info "Step 4/6: Pre-installing recipe modules to stabilise plugin registry..."
            print_warning "This prevents install-order errors (e.g. scheduler + layout_builder)..."
            cd /var/www/html/web
            # Suppress 'already enabled' warnings; a non-zero exit just means some were skipped.
            drush pm:enable --yes $RECIPE_MODULES > /dev/null 2>&1 || true
            drush cache:rebuild > /dev/null 2>&1 || true
            print_success "Modules pre-installed and cache rebuilt"
        else
            print_warning "Step 4/6: No modules found in recipe install list, skipping pre-install"
        fi
    else
        print_warning "Step 4/6: Skipping pre-install (no recipe.yml)"
    fi
    echo ""

    # Step 5: Apply recipe with Drush
    print_info "Step 5/6: Applying recipe with Drush..."
    print_warning "This will install modules, import configuration, and apply config actions..."
    echo ""

    cd /var/www/html/web
    if drush recipe "../recipes/$RECIPE_NAME"; then
        echo ""
        print_success "Recipe applied successfully!"
        echo ""
        print_info "Summary:"
        if [ -f "$RECIPE_PATH/composer.json" ]; then
            echo "  • Dependencies from recipes/$RECIPE_NAME/composer.json merged into root composer.json"
        fi
        echo "  • Recipe configuration applied"
        echo "  • Modules and themes installed"
        echo "  • Config imported and actions executed"
    else
        print_error "Failed to apply recipe with Drush"
        return 1
    fi

    echo ""
    print_info "Step 6/6: Complete!"
    return 0
}

# Interactive mode or direct recipe application
if [ -z "$1" ]; then
    # Interactive mode - list all recipes
    print_info "Available recipes:"
    echo ""
    
    RECIPES_DIR="/var/www/html/recipes"
    RECIPE_LIST=()
    RECIPE_INDEX=0
    
    # Build list of non-excluded recipes
    for recipe_dir in "$RECIPES_DIR"/*/; do
        if [ -d "$recipe_dir" ]; then
            recipe_name=$(basename "$recipe_dir")
            
            # Skip if excluded
            if is_excluded "$recipe_name"; then
                continue
            fi
            
            # Only include if recipe.yml exists
            if [ -f "$recipe_dir/recipe.yml" ]; then
                RECIPE_LIST+=("$recipe_name")
                display_name=$(get_recipe_display_name "$recipe_dir")
                echo "  [$RECIPE_INDEX] $recipe_name - $display_name"
                RECIPE_INDEX=$((RECIPE_INDEX + 1))
            fi
        fi
    done
    
    if [ ${#RECIPE_LIST[@]} -eq 0 ]; then
        echo ""
        print_error "No recipes found in recipes/"
        exit 1
    fi
    
    echo ""
    echo "Enter recipe number(s) separated by commas (e.g., 0,2,4) or 'q' to quit:"
    read -r selection
    
    if [ "$selection" = "q" ] || [ "$selection" = "Q" ]; then
        echo "Cancelled"
        exit 0
    fi
    
    # Parse comma-separated selections
    IFS=',' read -ra SELECTIONS <<< "$selection"
    FAILED_RECIPES=()
    
    for sel in "${SELECTIONS[@]}"; do
        # Trim whitespace
        sel=$(echo "$sel" | xargs)
        
        # Validate selection is a number
        if ! [[ "$sel" =~ ^[0-9]+$ ]]; then
            print_error "Invalid selection: $sel"
            continue
        fi
        
        # Check if selection is in range
        if [ "$sel" -lt 0 ] || [ "$sel" -ge ${#RECIPE_LIST[@]} ]; then
            print_error "Selection out of range: $sel (valid: 0-$((${#RECIPE_LIST[@]} - 1)))"
            continue
        fi
        
        RECIPE_NAME="${RECIPE_LIST[$sel]}"
        echo ""
        echo "=========================================="
        echo "Applying recipe [$sel]: $RECIPE_NAME"
        echo "=========================================="
        echo ""
        
        if ! apply_recipe "$RECIPE_NAME"; then
            FAILED_RECIPES+=("$RECIPE_NAME")
        fi
    done
    
    # Report any failures
    if [ ${#FAILED_RECIPES[@]} -gt 0 ]; then
        echo ""
        print_error "Failed to apply ${#FAILED_RECIPES[@]} recipe(s):"
        for failed in "${FAILED_RECIPES[@]}"; do
            echo "  • $failed"
        done
        exit 1
    fi
    
    exit 0
fi

# Direct recipe name provided
RECIPE_NAME="$1"

if apply_recipe "$RECIPE_NAME"; then
    exit 0
else
    exit 1
fi
